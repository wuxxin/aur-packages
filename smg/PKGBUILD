# Maintainer: Antigravity AI <antigravity@google.com>

pkgbase=smg
pkgname=('smg' 'python-smg')
pkgver=1.8.0
pkgrel=1
pkgdesc="High-performance model-routing gateway for large-scale LLM deployments"
arch=('x86_64')
url="https://github.com/lightseekorg/smg"
license=('Apache-2.0')
makedepends=('cargo' 'maturin' 'python-build' 'python-installer' 'python-wheel' 'openssl' 'protobuf' 'cmake')
source=("${pkgbase}-${pkgver}.tar.gz::https://github.com/lightseekorg/smg/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('cccaf1a43f1350bbef10029c6a07039ffb8241353ce3dd8a1fda786b7d4b1afd')

prepare() {
    cd "${srcdir}/${pkgbase}-${pkgver}"
    export CARGO_HOME="${srcdir}/cargo-home"
    cargo fetch --locked || cargo fetch
}

build() {
    cd "${srcdir}/${pkgbase}-${pkgver}"
    export CARGO_HOME="${srcdir}/cargo-home"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR="${srcdir}/target"

    # Fix aws-lc-sys static link failure with LLVM lld by forcing GNU bfd linker and stripping --as-needed
    export RUSTFLAGS="-C link-arg=-fuse-ld=bfd"
    export LDFLAGS="${LDFLAGS//-Wl,--as-needed/}"

    echo "Building standalone Rust binaries..."
    cargo build --release --bin smg --bin amg

    echo "Building Python wheel with maturin..."
    cd bindings/python
    maturin build --release --out "${srcdir}/dist"
}

package_smg() {
    pkgdesc="High-performance model-routing gateway for large-scale LLM deployments (standalone Rust binary)"
    depends=('gcc-libs' 'glibc' 'openssl')
    provides=('smg')
    conflicts=('smg')

    cd "${srcdir}/${pkgbase}-${pkgver}"
    install -Dm755 "${srcdir}/target/release/smg" -t "${pkgdir}/usr/bin/"
    install -Dm755 "${srcdir}/target/release/amg" -t "${pkgdir}/usr/bin/"
    install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}

package_python-smg() {
    pkgdesc="High-performance model-routing gateway for large-scale LLM deployments (Python bindings & CLI)"
    depends=('python' 'python-setproctitle' 'python-grpcio' 'python-yaml')
    optdepends=('python-httpx: HTTP client support' 'python-pydantic: Pydantic models support')
    provides=('python-smg')
    conflicts=('python-smg')

    cd "${srcdir}/${pkgbase}-${pkgver}"
    python -m installer --destdir="${pkgdir}" "${srcdir}/dist/"*.whl

    # Embed pre-generated grpc_health stubs to ensure self-contained operation without missing AUR packages
    local site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
    local grpc_health_dir="${pkgdir}${site_packages}/grpc_health/v1"
    mkdir -p "${grpc_health_dir}"

    cat <<'EOF' > "${grpc_health_dir}/__init__.py"
# Generated gRPC health checking stubs
EOF

    cat <<'EOF' > "${grpc_health_dir}/health_pb2.py"
# -*- coding: utf-8 -*-
from google.protobuf import descriptor as _descriptor
from google.protobuf import descriptor_pool as _descriptor_pool
from google.protobuf import symbol_database as _symbol_database
from google.protobuf.internal import builder as _builder
_sym_db = _symbol_database.Default()
DESCRIPTOR = _descriptor_pool.Default().AddSerializedFile(b'\n\x1cgrpc/health/v1/health.proto\x12\x0egrpc.health.v1\"%\n\x12HealthCheckRequest\x12\x0f\n\x07service\x18\x01 \x01(\t\"\xa9\x01\n\x13HealthCheckResponse\x12\x41\n\x06status\x18\x01 \x01(\x0e\x32\x31.grpc.health.v1.HealthCheckResponse.ServingStatus\"O\n\rServingStatus\x12\x0b\n\x07UNKNOWN\x10\x00\x12\x0b\n\x07SERVING\x10\x01\x12\x0f\n\x0bNOT_SERVING\x10\x02\x12\x13\n\x0fSERVICE_UNKNOWN\x10\x03\x32\xae\x01\n\x06Health\x12P\n\x05\x43heck\x12".grpc.health.v1.HealthCheckRequest\x13".grpc.health.v1.HealthCheckResponse\x12R\n\x05Watch\x12".grpc.health.v1.HealthCheckRequest\x13".grpc.health.v1.HealthCheckResponse0\x01\x42\x61\n\x11io.grpc.health.v1B\x0bHealthProtoP\x01ZZQgithub.com/grpc/grpc-go/health/grpc_health_v1\xaa\x02\x0eGPRC.Health.V1b\x06proto3')
_globals = globals()
_builder.BuildMessageAndEnumDescriptors(DESCRIPTOR, _globals)
_builder.BuildTopDescriptorsAndMessages(DESCRIPTOR, 'grpc.health.v1.health_pb2', _globals)
EOF

    cat <<'EOF' > "${grpc_health_dir}/health_pb2_grpc.py"
# Generated by the gRPC Python protocol compiler plugin.
import grpc

from grpc_health.v1 import health_pb2 as grpc_dot_health_dot_v1_dot_health__pb2

class HealthStub(object):
    def __init__(self, channel):
        self.Check = channel.unary_unary(
                '/grpc.health.v1.Health/Check',
                request_serializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckRequest.SerializeToString,
                response_deserializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckResponse.FromString,
                )
        self.Watch = channel.unary_stream(
                '/grpc.health.v1.Health/Watch',
                request_serializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckRequest.SerializeToString,
                response_deserializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckResponse.FromString,
                )

class HealthServicer(object):
    def Check(self, request, context):
        context.set_code(grpc.StatusCode.UNIMPLEMENTED)
        context.set_details('Method not implemented!')
        raise NotImplementedError('Method not implemented!')

    def Watch(self, request, context):
        context.set_code(grpc.StatusCode.UNIMPLEMENTED)
        context.set_details('Method not implemented!')
        raise NotImplementedError('Method not implemented!')

def add_HealthServicer_to_server(servicer, server):
    rpc_method_handlers = {
            'Check': grpc.unary_unary_rpc_method_handler(
                    servicer.Check,
                    request_deserializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckRequest.FromString,
                    response_serializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckResponse.SerializeToString,
            ),
            'Watch': grpc.unary_stream_rpc_method_handler(
                    servicer.Watch,
                    request_deserializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckRequest.FromString,
                    response_serializer=grpc_dot_health_dot_v1_dot_health__pb2.HealthCheckResponse.SerializeToString,
            ),
    }
    generic_handler = grpc.method_handlers_generic_handler(
            'grpc.health.v1.Health', rpc_method_handlers)
    server.add_generic_rpc_handlers((generic_handler,))
EOF

    install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
