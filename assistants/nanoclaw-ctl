#!/usr/bin/env bash
set -euo pipefail

# nanoclaw-ctl - installation and management wrapper for nanoclaw

SERVICE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/nanoclaw.service"
ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/nanoclaw.env"
NANOCLAW_HOME="$HOME/.local/share/nanoclaw"

cmd_install() {
	echo "Setting up nanoclaw home directory at $NANOCLAW_HOME..."
	mkdir -p "$NANOCLAW_HOME"

	echo "Generating systemd user service..."
	mkdir -p "$(dirname "$SERVICE_FILE")"

	if [ ! -f "$ENV_FILE" ]; then
		cat >"$ENV_FILE" <<'EOF'
# nanoclaw.env
# ---------------------------------------------------------------------------
# WEBHOOK_PORT: Webhook port for NanoClaw (default 3000)
WEBHOOK_PORT=3000
EOF
		chmod 600 "$ENV_FILE"
	fi

	cat >"$SERVICE_FILE" <<'EOF'
[Unit]
Description=NanoClaw Webhook Server and Agent Runner
Documentation=https://github.com/nanocoai/nanoclaw
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=%h/.local/share/nanoclaw
EnvironmentFile=-%h/.config/systemd/user/nanoclaw.env
WorkingDirectory=%h/.local/share/nanoclaw
ExecStart=/usr/bin/nanoclaw start
Restart=on-failure
RestartSec=5s
TimeoutStopSec=30

StandardOutput=journal
StandardError=journal
SyslogIdentifier=nanoclaw

# Security measures
NoNewPrivileges=yes
CapabilityBoundingSet=
AmbientCapabilities=

# Filesystem hiding
ProtectSystem=strict
TemporaryFileSystem=%h
BindPaths=%h/.local/share/nanoclaw:%h/.local/share/nanoclaw
BindPaths=%h/agent-shared:%h/agent-shared
# Podman/Docker socket requires access to run containers
ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf
PrivateTmp=yes
# We need to disable PrivateDevices if containers are used, but we'll try keeping it enabled unless Docker/Podman is used inside via socket.
PrivateDevices=no
PrivateMounts=yes

# Kernel and IPC constraints
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
LockPersonality=yes
MemoryDenyWriteExecute=no
SystemCallArchitectures=native
PrivateIPC=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
KeyringMode=private
UMask=0077

# Note: ProtectProc=invisible, ProcSubset=pid, and RestrictNamespaces=yes
# are explicitly omitted to allow child processes to use namespaces (containers/podman).

[Install]
WantedBy=default.target
EOF

	echo "Reloading systemd and enabling service..."
	systemctl --user daemon-reload
	systemctl --user enable nanoclaw.service

	echo "Starting service automatically..."
	systemctl --user start nanoclaw.service

	echo "Done! Type '$0 logs' to see the output."
}

cmd_uninstall() {
	echo "Uninstalling nanoclaw systemd service..."
	systemctl --user stop nanoclaw.service || true
	systemctl --user disable nanoclaw.service || true

	if [ -f "$SERVICE_FILE" ]; then
		rm "$SERVICE_FILE"
		systemctl --user daemon-reload
		echo "Removed service file."
	fi
	echo "Uninstalled successfully. Data in $NANOCLAW_HOME is preserved."
}

cmd_start() { systemctl --user start nanoclaw.service; }
cmd_stop() { systemctl --user stop nanoclaw.service; }
cmd_restart() { systemctl --user restart nanoclaw.service; }
cmd_status() { systemctl --user status nanoclaw.service; }
cmd_enable() { systemctl --user enable nanoclaw.service; }
cmd_disable() { systemctl --user disable nanoclaw.service; }
cmd_logs() { journalctl --user -u nanoclaw.service -f; }

cmd_edit() {
	mkdir -p "$(dirname "$ENV_FILE")"
	touch "$ENV_FILE"
	${EDITOR:-nano} "$ENV_FILE"
	echo "Restarting service to apply updated environment..."
	cmd_restart
}

cmd_exec() {
	echo "Starting nanoclaw as a transient systemd service with args: $*"

	local opts=(
		--user
		--pty
		--wait
		--collect
		--quiet
		-p "Type=exec"
		-p "Environment=HOME=$HOME/.local/share/nanoclaw"
		-p "EnvironmentFile=-$HOME/.config/systemd/user/nanoclaw.env"
		-p "WorkingDirectory=$HOME/.local/share/nanoclaw"
		-p "NoNewPrivileges=yes"
		-p "CapabilityBoundingSet="
		-p "AmbientCapabilities="
		-p "ProtectSystem=strict"
		-p "TemporaryFileSystem=$HOME"
		-p "BindPaths=$HOME/.local/share/nanoclaw:$HOME/.local/share/nanoclaw"
		-p "BindPaths=$HOME/agent-shared:$HOME/agent-shared"
		-p "ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf"
		-p "PrivateTmp=yes"
		-p "PrivateDevices=no"
		-p "PrivateMounts=yes"
		-p "ProtectKernelTunables=yes"
		-p "ProtectKernelModules=yes"
		-p "ProtectKernelLogs=yes"
		-p "ProtectControlGroups=yes"
		-p "ProtectClock=yes"
		-p "ProtectHostname=yes"
		-p "LockPersonality=yes"
		-p "MemoryDenyWriteExecute=no"
		-p "SystemCallArchitectures=native"
		-p "PrivateIPC=yes"
		-p "RestrictSUIDSGID=yes"
		-p "RestrictRealtime=yes"
		-p "KeyringMode=private"
		-p "UMask=0077"
	)

	systemd-run "${opts[@]}" /usr/bin/nanoclaw "$@"
}

cmd_shell() {
	echo "Starting interactive shell as a transient systemd service..."

	local opts=(
		--user
		--pty
		--wait
		--collect
		--quiet
		-p "Type=exec"
		-p "Environment=HOME=$HOME/.local/share/nanoclaw"
		-p "EnvironmentFile=-$HOME/.config/systemd/user/nanoclaw.env"
		-p "WorkingDirectory=$HOME/.local/share/nanoclaw"
		-p "NoNewPrivileges=yes"
		-p "CapabilityBoundingSet="
		-p "AmbientCapabilities="
		-p "ProtectSystem=strict"
		-p "TemporaryFileSystem=$HOME"
		-p "BindPaths=$HOME/.local/share/nanoclaw:$HOME/.local/share/nanoclaw"
		-p "BindPaths=$HOME/agent-shared:$HOME/agent-shared"
		-p "ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf"
		-p "PrivateTmp=yes"
		-p "PrivateDevices=no"
		-p "PrivateMounts=yes"
		-p "ProtectKernelTunables=yes"
		-p "ProtectKernelModules=yes"
		-p "ProtectKernelLogs=yes"
		-p "ProtectControlGroups=yes"
		-p "ProtectClock=yes"
		-p "ProtectHostname=yes"
		-p "LockPersonality=yes"
		-p "MemoryDenyWriteExecute=no"
		-p "SystemCallArchitectures=native"
		-p "PrivateIPC=yes"
		-p "RestrictSUIDSGID=yes"
		-p "RestrictRealtime=yes"
		-p "KeyringMode=private"
		-p "UMask=0077"
	)

	systemd-run "${opts[@]}" "${SHELL:-/bin/bash}" "$@"
}

usage() {
	echo "Usage: $0 <command>"
	echo "Commands:"
	echo "  install   - Setup service and nanoclaw home directory"
	echo "  uninstall - Stop and remove systemd service"
	echo "  start     - Start the systemd service"
	echo "  stop      - Stop the systemd service"
	echo "  restart   - Restart the systemd service"
	echo "  status    - View systemd service status"
	echo "  enable    - Enable systemd service on boot"
	echo "  disable   - Disable systemd service on boot"
	echo "  logs      - Tail the systemd service logs"
	echo "  edit      - Edit the .env file and restart the service upon exit"
	echo "  exec      - Run nanoclaw as a transient systemd user service with args"
	echo "  shell     - Spawn an interactive shell in the nanoclaw systemd environment"
}

if [ $# -lt 1 ]; then
	usage
	exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
install) cmd_install ;;
uninstall) cmd_uninstall ;;
start) cmd_start ;;
stop) cmd_stop ;;
restart) cmd_restart ;;
status) cmd_status ;;
enable) cmd_enable ;;
disable) cmd_disable ;;
logs) cmd_logs ;;
edit) cmd_edit ;;
exec) cmd_exec "$@" ;;
shell) cmd_shell "$@" ;;
*)
	echo "Unknown command: $COMMAND"
	usage
	exit 1
	;;
esac
