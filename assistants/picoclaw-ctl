#!/usr/bin/env bash
set -euo pipefail

# picoclaw-ctl - installation and management wrapper for picoclaw

SERVICE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/picoclaw.service"
ENV_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/picoclaw.env"
PICOCLAW_HOME="$HOME/.local/share/picoclaw"

write_service_file() {
    local AGENT_PRIVATE_MOUNTS=""
    if [ -f "$ENV_FILE" ]; then
        set +u
        source "$ENV_FILE"
        set -u
    fi

    local mount_binds=""
    for m in ${AGENT_PRIVATE_MOUNTS:-}; do
        mkdir -p "$HOME/agent-private/$m"
        mount_binds="${mount_binds}BindPaths=%h/agent-private/$m:%h/agent-private/$m"$'\n'
    done

    cat >"$SERVICE_FILE" <<EOF
[Unit]
Description=PicoClaw Launcher web console service
Documentation=https://github.com/sipeed/picoclaw
After=network.target

[Service]
Type=simple
Environment=PICOCLAW_HOME=%h/.local/share/picoclaw
Environment=PICOCLAW_CONFIG=%h/.local/share/picoclaw/config.json
Environment=PICOCLAW_BINARY=/usr/bin/picoclaw
Environment=HOME=%h
EnvironmentFile=-%h/.config/systemd/user/picoclaw.env
WorkingDirectory=%h
ExecStart=/usr/bin/picoclaw-launcher -no-browser
Restart=on-failure
RestartSec=5s

StandardOutput=journal
StandardError=journal
SyslogIdentifier=picoclaw

NoNewPrivileges=yes
CapabilityBoundingSet=
AmbientCapabilities=

ProtectSystem=strict
TemporaryFileSystem=%h
# Retain changes by bind mounting the explicit picoclaw home directory
BindPaths=%h/.local/share/picoclaw:%h/.local/share/picoclaw
BindPaths=%h/agent-shared:%h/agent-shared
${mount_binds}ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf
PrivateTmp=yes
PrivateDevices=yes
PrivateMounts=yes

ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
ProcSubset=pid
RestrictNamespaces=yes
LockPersonality=yes

MemoryDenyWriteExecute=yes
SystemCallArchitectures=native

PrivateIPC=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
KeyringMode=private
UMask=0077

[Install]
WantedBy=default.target
EOF

    systemctl --user daemon-reload
}

cmd_install() {
    echo "Setting up picoclaw home directory at $PICOCLAW_HOME..."
    mkdir -p "$PICOCLAW_HOME"

    echo "Generating systemd user service..."
    mkdir -p "$(dirname "$SERVICE_FILE")"

    if [ ! -f "$ENV_FILE" ]; then
        cat >"$ENV_FILE" <<'EOF'
# picoclaw.env
# ---------------------------------------------------------------------------
# PicoClaw Environment Configuration
# ---------------------------------------------------------------------------

# List of submounts from ~/agent-private/* to bind-mount into the sandbox
# (e.g., AGENT_PRIVATE_MOUNTS="health diary" binds ~/agent-private/health and ~/agent-private/diary)
# AGENT_PRIVATE_MOUNTS=""
EOF
        chmod 600 "$ENV_FILE"
    fi

    write_service_file

    echo "Reloading systemd and enabling service..."
    systemctl --user enable picoclaw.service

    echo "Starting service automatically..."
    systemctl --user start picoclaw.service

    echo "Done! Type '$0 logs' to see the output."
}

cmd_uninstall() {
    echo "Uninstalling picoclaw systemd service..."
    systemctl --user stop picoclaw.service || true
    systemctl --user disable picoclaw.service || true

    if [ -f "$SERVICE_FILE" ]; then
        rm "$SERVICE_FILE"
        systemctl --user daemon-reload
        echo "Removed service file."
    fi
    echo "Uninstalled successfully. Data in $PICOCLAW_HOME is preserved."
}

cmd_start() {
    write_service_file
    systemctl --user start picoclaw.service
}

cmd_stop() {
    systemctl --user stop picoclaw.service
}

cmd_restart() {
    write_service_file
    systemctl --user restart picoclaw.service
}

cmd_status() {
    systemctl --user status picoclaw.service
}

cmd_enable() {
    write_service_file
    systemctl --user enable picoclaw.service
}

cmd_disable() {
    systemctl --user disable picoclaw.service
}

cmd_logs() {
    journalctl --user -u picoclaw.service -f
}

cmd_edit() {
    mkdir -p "$(dirname "$ENV_FILE")"
    touch "$ENV_FILE"
    ${EDITOR:-nano} "$ENV_FILE"
    echo "Restarting service to apply updated environment..."
    cmd_restart
}

cmd_exec() {
    echo "Starting picoclaw as a transient systemd service with args: $*"

    local opts=(
        --user
        --pty
        --wait
        --collect
        --quiet
        -p "Type=exec"
        -p "Environment=PICOCLAW_HOME=$HOME/.local/share/picoclaw"
        -p "Environment=PICOCLAW_CONFIG=$HOME/.local/share/picoclaw/config.json"
        -p "Environment=PICOCLAW_BINARY=/usr/bin/picoclaw"
        -p "Environment=HOME=$HOME"
        -p "EnvironmentFile=-$HOME/.config/systemd/user/picoclaw.env"
        -p "WorkingDirectory=$HOME"
        -p "NoNewPrivileges=yes"
        -p "CapabilityBoundingSet="
        -p "AmbientCapabilities="
        -p "ProtectSystem=strict"
        -p "TemporaryFileSystem=$HOME"
        -p "BindPaths=$HOME/.local/share/picoclaw:$HOME/.local/share/picoclaw"
        -p "BindPaths=$HOME/agent-shared:$HOME/agent-shared"
    )

    local AGENT_PRIVATE_MOUNTS=""
    if [ -f "$ENV_FILE" ]; then
        set +u
        source "$ENV_FILE"
        set -u
    fi
    for m in ${AGENT_PRIVATE_MOUNTS:-}; do
        mkdir -p "$HOME/agent-private/$m"
        opts+=(-p "BindPaths=$HOME/agent-private/$m:$HOME/agent-private/$m")
    done

    opts+=(
        -p "ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf"
        -p "PrivateTmp=yes"
        -p "PrivateDevices=yes"
        -p "PrivateMounts=yes"
        -p "ProtectKernelTunables=yes"
        -p "ProtectKernelModules=yes"
        -p "ProtectKernelLogs=yes"
        -p "ProtectControlGroups=yes"
        -p "ProtectClock=yes"
        -p "ProtectHostname=yes"
        -p "ProtectProc=invisible"
        -p "ProcSubset=pid"
        -p "RestrictNamespaces=yes"
        -p "LockPersonality=yes"
        -p "MemoryDenyWriteExecute=yes"
        -p "SystemCallArchitectures=native"
        -p "PrivateIPC=yes"
        -p "RestrictSUIDSGID=yes"
        -p "RestrictRealtime=yes"
        -p "KeyringMode=private"
        -p "UMask=0077"
    )

    systemd-run "${opts[@]}" /usr/bin/picoclaw "$@"
}

cmd_shell() {
    echo "Starting interactive shell as a transient systemd service..."

    local opts=(
        --user
        --pty
        --wait
        --collect
        --quiet
        -p "Type=exec"
        -p "Environment=PICOCLAW_HOME=$HOME/.local/share/picoclaw"
        -p "Environment=PICOCLAW_CONFIG=$HOME/.local/share/picoclaw/config.json"
        -p "Environment=PICOCLAW_BINARY=/usr/bin/picoclaw"
        -p "Environment=HOME=$HOME"
        -p "EnvironmentFile=-$HOME/.config/systemd/user/picoclaw.env"
        -p "WorkingDirectory=$HOME"
        -p "NoNewPrivileges=yes"
        -p "CapabilityBoundingSet="
        -p "AmbientCapabilities="
        -p "ProtectSystem=strict"
        -p "TemporaryFileSystem=$HOME"
        -p "BindPaths=$HOME/.local/share/picoclaw:$HOME/.local/share/picoclaw"
        -p "BindPaths=$HOME/agent-shared:$HOME/agent-shared"
    )

    local AGENT_PRIVATE_MOUNTS=""
    if [ -f "$ENV_FILE" ]; then
        set +u
        source "$ENV_FILE"
        set -u
    fi
    for m in ${AGENT_PRIVATE_MOUNTS:-}; do
        mkdir -p "$HOME/agent-private/$m"
        opts+=(-p "BindPaths=$HOME/agent-private/$m:$HOME/agent-private/$m")
    done

    opts+=(
        -p "ReadOnlyPaths=/etc/ssl /etc/ca-certificates /etc/resolv.conf /etc/hosts /etc/nsswitch.conf"
        -p "PrivateTmp=yes"
        -p "PrivateDevices=yes"
        -p "PrivateMounts=yes"
        -p "ProtectKernelTunables=yes"
        -p "ProtectKernelModules=yes"
        -p "ProtectKernelLogs=yes"
        -p "ProtectControlGroups=yes"
        -p "ProtectClock=yes"
        -p "ProtectHostname=yes"
        -p "ProtectProc=invisible"
        -p "ProcSubset=pid"
        -p "RestrictNamespaces=yes"
        -p "LockPersonality=yes"
        -p "MemoryDenyWriteExecute=yes"
        -p "SystemCallArchitectures=native"
        -p "PrivateIPC=yes"
        -p "RestrictSUIDSGID=yes"
        -p "RestrictRealtime=yes"
        -p "KeyringMode=private"
        -p "UMask=0077"
    )

    systemd-run "${opts[@]}" "${SHELL:-/bin/bash}" "$@"
}

usage() {
    echo "Usage: $0 <command>"
    echo "Commands:"
    echo "  install   - Setup service and picoclaw home directory"
    echo "  uninstall - Stop and remove systemd service"
    echo "  start     - Start the systemd service"
    echo "  stop      - Stop the systemd service"
    echo "  restart   - Restart the systemd service"
    echo "  status    - View systemd service status"
    echo "  enable    - Enable systemd service on boot"
    echo "  disable   - Disable systemd service on boot"
    echo "  logs      - Tail the systemd service logs"
    echo "  edit      - Edit the .env file and restart the service upon exit"
    echo "  exec      - Run picoclaw as a transient systemd user service with args"
    echo "  shell     - Spawn an interactive shell in the picoclaw systemd environment"
}

if [ $# -lt 1 ]; then
    usage
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
install) cmd_install ;;
uninstall) cmd_uninstall ;;
start) cmd_start ;;
stop) cmd_stop ;;
restart) cmd_restart ;;
status) cmd_status ;;
enable) cmd_enable ;;
disable) cmd_disable ;;
logs) cmd_logs ;;
edit) cmd_edit ;;
exec) cmd_exec "$@" ;;
shell) cmd_shell "$@" ;;
*)
    echo "Unknown command: $COMMAND"
    usage
    exit 1
    ;;
esac
