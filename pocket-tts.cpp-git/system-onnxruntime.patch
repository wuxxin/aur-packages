+static std::string get_default_voice(const std::string& models_dir) {
+    std::string dir = models_dir;
+    for (char& c : dir) {
+        c = std::tolower(static_cast<unsigned char>(c));
+    }
+    if (dir.find("german") != std::string::npos) return "juergen";
+    if (dir.find("italian") != std::string::npos) return "giovanni";
+    if (dir.find("spanish") != std::string::npos) return "lola";
+    if (dir.find("portuguese") != std::string::npos) return "rafael";
+    if (dir.find("french") != std::string::npos) return "estelle";
+    return "alba";
+}
