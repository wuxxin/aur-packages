# Maintainer: Wuxxin <wuxxin@gmail.com>

_pkgname=ironclaw-reborn
pkgname=ironclaw-reborn-git
pkgver=0.29.1.r1606.g414967d
pkgrel=1
pkgdesc='OpenClaw-inspired Rust personal AI assistant - Standalone Reborn CLI'
arch=('x86_64' 'aarch64')
url='https://github.com/nearai/ironclaw'
license=('Apache-2.0 OR MIT')
depends=('gcc-libs' 'glibc' 'postgresql-libs')
makedepends=('cargo' 'git' 'rust' 'nodejs' 'npm')
optdepends=(
    'postgresql: local PostgreSQL database support'
)
provides=("$_pkgname")
conflicts=("$_pkgname")
source=('git+https://github.com/nearai/ironclaw.git')
sha256sums=('SKIP')
options=('!lto')

pkgver() {
    cd "$srcdir"/ironclaw
    git describe --long --tags --match 'ironclaw-v*' --abbrev=7 | sed 's/^ironclaw-v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
    cd "$srcdir"/ironclaw
    cargo build --release --locked --package ironclaw_reborn_cli --bin ironclaw-reborn --all-features
}

check() {
    cd "$srcdir"/ironclaw
    cargo test --locked --package ironclaw_reborn_cli --all-features
}

package() {
    cd "$srcdir"/ironclaw

    install -vDm755 target/release/ironclaw-reborn "$pkgdir"/usr/bin/ironclaw-reborn
    install -vDm644 README.md "$pkgdir"/usr/share/doc/"$pkgname"/README.md
    install -vDm644 LICENSE-APACHE "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE-APACHE
    install -vDm644 LICENSE-MIT "$pkgdir"/usr/share/licenses/"$pkgname"/LICENSE-MIT
}
