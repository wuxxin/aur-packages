# Contributor: Evert <evorster at gmail dot com>

# This is the git-based version of hermes-agent using manual shallow clone depth=2000.
# It uses a venv-based installation built on top of the system's built-in Python with system packages enabled.
# Eagerly installs local CPU/GPU TTS (piper-tts, neutts) while avoiding runtime pip installs in /opt.

# GitHub PR numbers to download and apply as patches during prepare().
# Each PR is fetched as a .patch file from GitHub and applied with git apply.
# Example: _prs=(57668 12345)
_prs=(57668)

pkgname=hermes-agent-git
pkgver=0.18.0.r418.g6fad6f1dd
pkgrel=1
pkgdesc="Locally-run AI agent with tool use, web browsing, and automation (Git Main Branch)"
arch=('any')
options=('!strip')
url="https://github.com/NousResearch/hermes-agent"
license=('MIT')
provides=('hermes-agent')
conflicts=('hermes-agent')
depends=(
    'python'
    'ripgrep'
    'ffmpeg'
    'nss'
    'atk'
    'at-spi2-core'
    'cups'
    'libdrm'
    'libxkbcommon'
    'mesa'
    'pango'
    'cairo'
    'alsa-lib'
    'python-numpy'
    'python-onnxruntime'
    'python-huggingface-hub'
    'python-soundfile'
    'python-scipy'
)
makedepends=('python' 'nodejs' 'npm' 'rsync' 'git' 'curl')
source=('hermes-agent.install'
        'hermes-managed-pacman.patch'
        'python314-daemon-pool.patch')
sha256sums=('fff10d8e7839eaaa4847e04f1453259acfe99ba2221a49c32a24202bbc7ce5e2'
            'fafa699ac1bde48d6d1eeaaeff84cc6035599f099205965bd300bd5798c9c788'
            'cd94f825e4df766fed4606b9326a05fecefca731fcfa78f7fa5799af8ab67dca')
install=hermes-agent.install

pkgver() {
    cd "${srcdir}/hermes-agent"
    local _ver=$(grep -m 1 "^version = " pyproject.toml | cut -d '"' -f 2)
    local _rev=$(git rev-parse --short HEAD)
    local _count=$(git describe --long --tags 2>/dev/null | cut -d '-' -f 2)
    if [ -z "$_count" ] || ! [[ "$_count" =~ ^[0-9]+$ ]]; then
        _count="0"
    fi
    echo "${_ver}.r${_count}.g${_rev}"
}

prepare() {
    cd "${srcdir}"
    echo "==> Cloning hermes-agent main branch via shallow clone (depth 2000)..."
    if [ -d hermes-agent ]; then
        rm -rf hermes-agent
    fi
    git clone --depth 2000 https://github.com/NousResearch/hermes-agent.git hermes-agent || return 1

    cd hermes-agent
    # Add @askjo/camofox-browser to dependencies in package.json to fix Camofox installation
    sed -i 's|"agent-browser": "^0.26.0"|"agent-browser": "^0.26.0",\n    "@askjo/camofox-browser": "*"|' package.json

    # Raise requires-python ceiling to <3.15 to allow built-in python 3.14
    sed -i 's/requires-python = ">=3.11,<3.14"/requires-python = ">=3.11,<3.15"/' pyproject.toml

    # Patch OpenAI plugin image generation sizes to custom dimensions (768x512, 768x768, 512x768)
    python -c '
with open("plugins/image_gen/openai/__init__.py", "r") as f:
    code = f.read()
target = """_SIZES = {
    "landscape": "1536x1024",
    "square": "1024x1024",
    "portrait": "1024x1536",
}"""
replacement = """_SIZES = {
    "landscape": "768x512",
    "square": "768x768",
    "portrait": "512x768",
}"""
code = code.replace(target, replacement)
with open("plugins/image_gen/openai/__init__.py", "w") as f:
    f.write(code)
'

    # Apply GitHub PRs as patches
    for _pr in "${_prs[@]}"; do
        echo "==> Applying PR #${_pr}..."
        curl -sL "https://github.com/NousResearch/hermes-agent/pull/${_pr}.patch" \
            -o "${srcdir}/pr-${_pr}.patch"
        git apply "${srcdir}/pr-${_pr}.patch" || return 1
    done

    # Apply system package patch (pacman managed system, HERMES_SYSTEM_PKG gates)
    echo "==> Applying hermes-managed-pacman.patch..."
    git apply "${srcdir}/../hermes-managed-pacman.patch" || return 1

    # Apply Python 3.14 compatibility patch
    echo "==> Applying python314-daemon-pool.patch..."
    git apply "${srcdir}/../python314-daemon-pool.patch" || return 1
}

build() {
    cd "${srcdir}/hermes-agent"

    # vite-plugin-tailwindcss uses the ignore package which walks up the tree to read
    # .gitignore files. Creating an empty .git directory stops the scan at this level.
    [ ! -d .git ] && mkdir .git

    echo "==> Installing root Node.js dependencies (hoisted workspaces)..."
    if [ -f "package.json" ]; then
        npm install --no-fund --no-audit --progress=false || return 1
    fi

    echo "==> Building frontend..."
    if [ -d "web" ]; then
        cd web
        rm -f package-lock.json
        npm install || return 1
        npm run build || return 1
        cd ..
    fi

    echo "==> Building TUI..."
    if [ -d "ui-tui" ]; then
        cd ui-tui
        npm install --no-fund --no-audit --progress=false || return 1
        npm run build || return 1
        cd ..
    fi

    echo "==> Installing whatsapp-bridge dependencies..."
    if [ -f "scripts/whatsapp-bridge/package.json" ]; then
        (cd scripts/whatsapp-bridge && rm -f package-lock.json && npm install --legacy-peer-deps --omit=dev) || return 1
    fi

    echo "==> Creating Python venv with system site packages..."
    # Enable --system-site-packages so venv inherits working numpy and onnxruntime from system
    python -m venv --system-site-packages --clear venv || return 1
    venv/bin/pip install --upgrade pip || return 1

    # Eager-install everything except: voice (faster-whisper), matrix (python-olm / native builds), and local inference
    # This includes all cloud API clients (openai, anthropic, gemini, xai, bedrock, vertex, etc.) and Edge TTS
    venv/bin/pip install .[all] || return 1
    venv/bin/pip install .[messaging,edge-tts,firecrawl,exa,parallel-web,anthropic,fal] || return 1

    # Eager-install local TTS engines using --no-deps to avoid recompiling system packages
    echo "==> Eagerly installing local TTS engines (piper-tts, neutts)..."
    venv/bin/pip install --no-deps piper-tts neutts || return 1

    # Eager-install additional post-setup tools to prevent runtime installs in /opt
    echo "==> Eagerly installing post-setup tools (kittentts, ddgs)..."
    venv/bin/pip install --no-deps \
        "https://github.com/KittenML/KittenTTS/releases/download/0.8.1/kittentts-0.8.1-py3-none-any.whl" || return 1
    venv/bin/pip install ddgs || return 1
}

package() {
    cd "${srcdir}/hermes-agent"

    # Install to /opt/hermes-agent
    _optdir="$pkgdir/opt/hermes-agent"
    install -d "$_optdir"

    # Copy application files (include root node_modules and workspace packages)
    rsync -a --exclude='__pycache__' --exclude='.git' \
        --exclude='apps/*/node_modules' --exclude='web/node_modules' \
        --exclude='web/src' \
        --exclude='web/vite.config.ts' --exclude='web/tsconfig*.json' \
        --exclude='web/eslint.config.js' --exclude='web/README.md' \
        --exclude='ui-tui/src' --exclude='ui-tui/node_modules' \
        --exclude='scripts/tests' --exclude='scripts/install.*' \
        --exclude='build' \
        . "$_optdir/"

    # Remove Python 3.14 venv Easter egg symlink as it breaks bsdtar translation to UTF-8
    rm -f "$_optdir/venv/bin/𝜋thon"

    echo "console.log('skipping build, using prebuilt dist/entry.js')" >"$_optdir/ui-tui/scripts/build.mjs"

    # Dynamically determine python version in the created venv
    local _pyver=$(venv/bin/python -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')

    # Correct shebang in hermes launcher to use venv python
    sed -i "1c#!/opt/hermes-agent/venv/bin/python" "$_optdir/venv/bin/hermes"

    install -d "$_optdir/venv/lib/python${_pyver}/site-packages"
    {
        echo "import sys; sys.path.insert(0, \"/opt/hermes-agent\")"
    } >"$_optdir/venv/lib/python${_pyver}/site-packages/hermes.pth"

    install -d "$pkgdir/usr/bin"
    {
        echo "#!/bin/bash"
        echo "unset PYTHONPATH"
        echo "unset PYTHONHOME"
        echo 'export HERMES_SYSTEM_PKG=1'
        echo "exec /opt/hermes-agent/venv/bin/hermes" '"$@"'
    } >"$pkgdir/usr/bin/hermes"

    chmod 755 "$pkgdir/usr/bin/hermes"
}
