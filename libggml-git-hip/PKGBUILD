pkgver() {
    cd llama.cpp
    git describe --long --tags --abbrev=7 | sed -E 's/^[^0-9]*//;s/([^-]*-g)/r\1/;s/-/./g'
}

prepare() {
    # Patch ggml inside llama.cpp (patch path is ggml/src/...)
    cd "${srcdir}/llama.cpp"
    git submodule update --init --recursive
    patch -p1 <"${srcdir}/llama-cmake-include.patch"

    # Manually create ggml.pc.in if it's missing (needed for shared library build)
    if [ ! -f "ggml/ggml.pc.in" ]; then
        echo "Restoring missing ggml/ggml.pc.in"
        cp "${srcdir}/ggml.pc.in" "ggml/ggml.pc.in"
    fi

    # Prepare python binding to use system library path
    cd "${srcdir}/llama-cpp-python"
    patch -p0 <"${srcdir}/llama-cpp-system.patch"

    # Fix undefined symbols by aliasing them to llama_missing_symbol_dummy (defined in llama_shims.py)
    # This avoids import-time errors while ensuring a clean crash if actually called.
    local _MISSING_SYMBOLS=(
        "llama_get_kv_self"
        "llama_set_adapter_lora"
        "llama_rm_adapter_lora"
        "llama_clear_adapter_lora"
        "llama_apply_adapter_cvec"
        "llama_kv_self_can_shift"
        "llama_kv_self_clear"
        "llama_kv_self_defrag"
        "llama_kv_self_n_tokens"
        "llama_kv_self_seq_add"
        "llama_kv_self_seq_cp"
        "llama_kv_self_seq_div"
        "llama_kv_self_seq_keep"
        "llama_kv_self_seq_pos_max"
        "llama_kv_self_seq_pos_min"
        "llama_kv_self_seq_rm"
        "llama_kv_self_update"
        "llama_kv_self_used_cells"
        "llama_sampler_init_softmax"
    )
    for sym in "${_MISSING_SYMBOLS[@]}"; do
        sed -i "s|\"${sym}\"|\"llama_get_memory\"|" llama_cpp/llama_cpp.py
    done

    # Patch ABI mismatches in llama_cpp.py
    python3 "${srcdir}/llama-patch-abi.py" "llama_cpp/llama_cpp.py"

    # Inject Shims (LoRA, Samplers, etc.)
    cat "${srcdir}/llama-shims.py" >>llama_cpp/llama_cpp.py

    # Patch whisper.cpp
    cd "${srcdir}/whisper.cpp"
    patch -p1 <"${srcdir}/whisper-version-commit.patch"

    # Prepare stable-diffusion.cpp submodules
    cd "${srcdir}/stable-diffusion.cpp"
    git submodule init
    git config submodule.examples/server/frontend.url "${srcdir}/sdcpp-webui"
    git config submodule.thirdparty/libwebm.url "${srcdir}/libwebm"
    git config submodule.thirdparty/libwebp.update none
    git config submodule.ggml.update none
    git -c protocol.file.allow=always submodule update

    # Copy internal ggml headers for stable-diffusion.cpp's graph cut module
    mkdir -p "${srcdir}/stable-diffusion.cpp/ggml/src"
    cp -r "${srcdir}/llama.cpp/ggml/src/"* "${srcdir}/stable-diffusion.cpp/ggml/src/"

    # prepare qwen3-tts
    cd "${srcdir}/qwen3-tts.cpp"
    patch -p1 <"${srcdir}/qwen3-tts-system-ggml.patch"
    patch -p1 <"${srcdir}/qwen3-tts-threading.patch"
    patch -p1 <"${srcdir}/qwen3-tts-backend-allocation.patch"
    patch -p1 <"${srcdir}/qwen3-tts-hybrid-backend.patch"
    patch -p1 <"${srcdir}/qwen3-tts-dl-shims.patch"
    patch -p1 <"${srcdir}/qwen3-tts-voice-fallback.patch"
    patch -p1 <"${srcdir}/qwen3-tts-device.patch"
    patch -p1 <"${srcdir}/qwen3-tts-server-language.patch"
    patch -p1 <"${srcdir}/qwen3-tts-version-commit.patch"
    cp "${srcdir}/llama.cpp/LICENSE" "${srcdir}/qwen3-tts.cpp/LICENSE"

    # Prepare crispasr
    cd "${srcdir}/crispasr"
    git submodule update --init --recursive
    patch -p1 <"${srcdir}/fix-opusfile-include-dirs.patch"
    sed -i 's|add_subdirectory(src)|include(GNUInstallDirs)\nadd_subdirectory(src)|' CMakeLists.txt
    sed -i 's|find_library(SENTENCEPIECE_LIB sentencepiece)|# find_library(SENTENCEPIECE_LIB sentencepiece)|' src/CMakeLists.txt

    # Patch system ggml inside llama.cpp using the python script
    python3 "${startdir}/patch-ggml.py" "${srcdir}"
}

build() {
    local _GPU_TARGETS
    local _BLACKLIST="gfx1103"
    _GPU_TARGETS=$(rocm-supported-gfx | tr ';' '\n' |
        grep -vFf <(echo "${_BLACKLIST//;/\\n}") | tr '\n' ';' | sed 's/;$//')
    if [[ -n "$AMDGPU_TARGETS" ]]; then _GPU_TARGETS="$AMDGPU_TARGETS"; fi
    if [[ -z "$_GPU_TARGETS" ]]; then _GPU_TARGETS="gfx1030"; fi

    export GPU_TARGETS="${_GPU_TARGETS}"
    export ROCM_HOME="${ROCM_HOME:-/opt/rocm}"
    export ROCM_PATH="$ROCM_HOME"
    export HIP_ROOT_DIR="$ROCM_HOME"
    export HIP_PLATFORM=amd
    export CC=gcc
    export CXX=g++

    # Clear flags that interfere with HIP/device compilation
    unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS
    export CFLAGS="-DGGML_MAX_NAME=128"
    export CXXFLAGS="-DGGML_MAX_NAME=128"
    export LDFLAGS=""
    export CPPFLAGS=""

    echo "Building HEAD for ROCm architectures: ${GPU_TARGETS}"

    # --- Build ggml FIRST (from llama.cpp/ggml subdir) ---
    # We use GGML_STANDALONE=OFF to bypass tests/examples that might be missing
    echo "--- Building libggml (Dynamic Backends) from llama.cpp/ggml ---"
    cmake -B build_ggml_hip -S llama.cpp/ggml -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DGGML_STANDALONE=OFF \
        -DGGML_BUILD_TESTS=OFF \
        -DGGML_BUILD_EXAMPLES=OFF \
        -DGGML_BACKEND_DL=ON \
        -DGGML_BACKEND_DIR="/usr/lib/ggml" \
        -DGGML_HIP=ON \
        -DGGML_HIPBLAS=ON \
        -DGGML_HIP_ROCWMMA_FATTN=ON \
        -DGGML_CUDA_FA_ALL_QUANTS=ON \
        -DAMDGPU_TARGETS="${GPU_TARGETS}" \
        -DGGML_VULKAN=ON \
        -DBUILD_SHARED_LIBS=ON \
        -DGGML_NATIVE=OFF \
        -DGGML_CPU_ALL_VARIANTS=ON \
        -DGGML_BLAS=ON \
        -DGGML_BLAS_VENDOR=OpenBLAS \
        -DCMAKE_HIP_COMPILER=/opt/rocm/bin/amdclang++

    cmake --build build_ggml_hip

    # Install ggml to staging directory
    DESTDIR="${srcdir}/staging_hip" cmake --install build_ggml_hip

    # --- Build llama.cpp using system ggml ---
    echo "--- Building llama.cpp (HIP) with system ggml ---"
    export CMAKE_PREFIX_PATH="${srcdir}/staging_hip/usr"
    cmake -B build_llama_hip -S llama.cpp -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DBUILD_SHARED_LIBS=ON \
        -DLLAMA_USE_SYSTEM_GGML=ON \
        -DLLAMA_BUILD_SERVER=ON \
        -DGGML_HIP=ON \
        -DGGML_HIPBLAS=ON \
        -DHIP_PLATFORM=amd \
        -DAMDGPU_TARGETS="${GPU_TARGETS}" \
        -DGGML_NATIVE=ON \
        -DCMAKE_HIP_COMPILER=/opt/rocm/bin/amdclang++
    cmake --build build_llama_hip

    # --- Build whisper.cpp using system ggml ---
    echo "--- Building whisper.cpp (HIP) ---"
    cmake -B build_whisper_hip -S whisper.cpp -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DWHISPER_SDL2=1 \
        -DWHISPER_USE_SYSTEM_GGML=1 \
        -DGGML_HIP=ON \
        -DGGML_HIPBLAS=ON \
        -DAMDGPU_TARGETS="${GPU_TARGETS}" \
        -DCMAKE_HIP_COMPILER=/opt/rocm/bin/amdclang++
    cmake --build build_whisper_hip

    # --- Build python-llama-cpp ---
    echo "--- Building python-llama-cpp (HIP) ---"
    cd llama-cpp-python
    export CMAKE_ARGS="-DLLAMA_BUILD=OFF"
    rm -rf build dist llama_cpp_python.egg-info
    python -m build --wheel --no-isolation
    mkdir -p "${srcdir}/dist_hip"
    mv dist/*.whl "${srcdir}/dist_hip/"
    cd ..

    # --- Build stable-diffusion.cpp using system ggml ---
    echo "--- Building stable-diffusion.cpp (HIP) ---"
    cmake -B build_sd_hip -S stable-diffusion.cpp -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DSD_BUILD_SHARED_LIBS=ON \
        -DSD_USE_SYSTEM_GGML=ON \
        -DSD_USE_SYSTEM_WEBP=ON \
        -DSD_USE_SYSTEM_WEBM=OFF \
        -DSD_HIPBLAS=ON
    cmake --build build_sd_hip

    # --- Build qwen3-tts.cpp using system ggml ---
    echo "--- Building qwen3-tts.cpp (HIP) ---"
    cmake -B build_qwen3_hip -S qwen3-tts.cpp -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DQWEN3_TTS_USE_SYSTEM_GGML=ON
    cmake --build build_qwen3_hip

    # --- Build crispasr using system ggml dynamically ---
    echo "--- Building CrispASR ---"
    cmake -B build_crispasr -S crispasr -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="/usr" \
        -DCRISPASR_USE_SYSTEM_GGML=ON \
        -DCRISPASR_BUILD_SERVER=ON \
        -DCRISPASR_BUILD_EXAMPLES=ON \
        -DCRISPASR_BUILD_TESTS=OFF \
        -DBUILD_SHARED_LIBS=OFF \
        -DSENTENCEPIECE_LIB=NOTFOUND
    cmake --build build_crispasr
}

package_libggml-git-hip() {
    pkgdesc="Tensor library for machine learning (Dynamic Backends: CPU, BLAS, HIP/ROCm, Vulkan, GIT HEAD)"
    provides=("libggml" "libggml-git" "libggml-git-hip" "libggml-git-vulkan")
    conflicts=("libggml" "libggml-git" "libggml-git-vulkan")
    depends=('hip-runtime-amd' 'hipblas' 'rocblas' 'openblas' 'vulkan-icd-loader')

    # Install from ggml build staging
    mkdir -p "${pkgdir}/usr"
    cp -r "${srcdir}/staging_hip/usr/"* "${pkgdir}/usr/"
}

package_llama.cpp-git-ggml-hip() {
    pkgdesc="Port of Facebook's LLaMA model in C/C++ (git shared library build)"
    depends=('libggml-git-hip' 'curl' 'hip-runtime-amd' 'hipblas' 'rocblas')
    provides=('llama.cpp' 'llama.cpp-hip')
    conflicts=('llama.cpp' 'llama.cpp-hip')

    DESTDIR="$pkgdir" cmake --install build_llama_hip

    # Install Arch-specific README
    install -Dm644 "${srcdir}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README-arch.md"
}

package_whisper.cpp-git-ggml-hip() {
    pkgdesc="Port of OpenAI's Whisper model (git shared library build)"
    depends=('libggml-git-hip' 'sdl2-compat' 'hip-runtime-amd')
    provides=('whisper.cpp' 'whisper.cpp-hip')

    DESTDIR="$pkgdir" cmake --install build_whisper_hip
}

package_python-llama-cpp-git-ggml-hip() {
    pkgdesc="Python bindings for llama.cpp (git shared library build)"
    depends=('llama.cpp-git-ggml-hip' 'libggml-git-hip' 'python-numpy')
    provides=('python-llama-cpp' 'python-llama-cpp-hip')

    cd llama-cpp-python
    python -m installer --destdir="$pkgdir" "${srcdir}/dist_hip/"*.whl
}

package_stable-diffusion.cpp-git-ggml-hip() {
    pkgdesc="Stable Diffusion in pure C/C++ (git shared library build)"
    depends=('libggml-git-hip' 'libwebp')
    provides=('stable-diffusion.cpp' 'stable-diffusion.cpp-hip')
    conflicts=('stable-diffusion.cpp' 'stable-diffusion.cpp-hip')

    DESTDIR="$pkgdir" cmake --install build_sd_hip

    install -Dm644 "${srcdir}/stable-diffusion.cpp/LICENSE" \
        -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

package_qwen3-tts.cpp-git-ggml-hip() {
    pkgdesc="C++ inference for Qwen3-TTS using the GGML tensor library (git shared library build)"
    depends=('libggml-git-hip')
    provides=('qwen3-tts.cpp')
    conflicts=('qwen3-tts.cpp')

    DESTDIR="$pkgdir" cmake --install build_qwen3_hip

    install -Dm644 "${srcdir}/qwen3-tts.cpp/LICENSE" \
        -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

package_crispasr-git-ggml-hip() {
    pkgdesc="C++ ggml runtime hub for ASR (fork of whisper.cpp) - git shared library build"
    depends=('libggml-git-hip' 'libgomp' 'vulkan-icd-loader' 'opusfile' 'opencore-amr' 'lame')
    provides=('crispasr')
    conflicts=('crispasr' 'crispasr-git' 'crispasr-release-git')

    DESTDIR="$pkgdir" cmake --install build_crispasr

    install -Dm644 "${srcdir}/crispasr/LICENSE" \
        -t "${pkgdir}/usr/share/licenses/${pkgname}"
}
