@@ -209,6 +208,27 @@ target_link_libraries(qwen3-tts-cli PRIVATE
     qwen3_tts
 )
 
+# Get git commit hash for versioning
+set(QWEN3_TTS_GIT_COMMIT "unknown")
+set(QWEN3_TTS_GIT_BRANCH "main")
+find_package(Git)
+if(Git_FOUND)
+    execute_process(
+        COMMAND ${GIT_EXECUTABLE} rev-parse --short HEAD
+        WORKING_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR}
+        OUTPUT_VARIABLE QWEN3_TTS_COMMIT_OUT
+        OUTPUT_STRIP_TRAILING_WHITESPACE
+        RESULT_VARIABLE RES
+    )
+    if(RES EQUAL 0)
+        set(QWEN3_TTS_GIT_COMMIT ${QWEN3_TTS_COMMIT_OUT})
+    endif()
+endif()
+
+target_compile_definitions(qwen3-tts-cli PRIVATE
+    QWEN3_TTS_VERSION="0.1-${QWEN3_TTS_GIT_BRANCH}-${QWEN3_TTS_GIT_COMMIT}"
+)
