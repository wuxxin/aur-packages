--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -45,9 +45,18 @@ endif()
 # PIC is needed for the shared library — set globally so GGML libs get it too
 set(CMAKE_POSITION_INDEPENDENT_CODE ON)
 
-# GGML as subdirectory — options like GGML_VULKAN, GGML_METAL pass through automatically
-set(GGML_DIR "${CMAKE_CURRENT_SOURCE_DIR}/ggml")
-add_subdirectory(${GGML_DIR})
+# GGML support (subdirectory or system package)
+option(QWEN3_TTS_USE_SYSTEM_GGML "Use system-installed GGML library" OFF)
+
+if(QWEN3_TTS_USE_SYSTEM_GGML)
+    find_package(ggml REQUIRED)
+    add_library(ggml ALIAS ggml::ggml)
+    set(GGML_INCLUDE_DIRS ${GGML_INCLUDE_DIR})
+else()
+    set(GGML_DIR "${CMAKE_CURRENT_SOURCE_DIR}/ggml")
+    add_subdirectory(${GGML_DIR})
+    set(GGML_INCLUDE_DIRS ${GGML_DIR}/include)
+endif()
 
 # Text tokenizer library
 add_library(text_tokenizer STATIC
